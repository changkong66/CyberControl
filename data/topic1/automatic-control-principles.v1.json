    "golden_questions": [
      {"schema_version": "topic1.golden-question.v1", "question_id": "QUESTION_ATC_TRANSFER_001", "primary_kp_id": "KP_ATC_301_TRANSFER_FUNCTION", "related_kp_ids": ["KP_ATC_201_PHYSICAL_MODELING", "KP_ATC_202_LAPLACE_TRANSFORM"], "question_type": "CALCULATION", "stem_markdown": "零初始条件下，系统满足 $\\dot y(t)+2y(t)=3u(t)$。求输入到输出的传递函数。", "answer_document": {"transfer_function": "3/(s+2)"}, "solution_markdown": "对微分方程作零初始条件拉普拉斯变换，得到 $(s+2)Y(s)=3U(s)$，因此 $G(s)=3/(s+2)$。", "difficulty_level": 2, "discrimination": 0.65, "diagnostic_tags": ["laplace", "zero-initial-condition", "transfer-function"], "misconception_ids": ["MISCONCEPTION_ATC_TRANSFER_INITIAL"], "authority_sources": [{"source_id": "TEXTBOOK_HU_AUTOMATIC_CONTROL_7E", "source_version": "7", "locator": "chapter:2"}], "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.golden-question.v1", "question_id": "QUESTION_ATC_SECOND_ORDER_001", "primary_kp_id": "KP_ATC_402_SECOND_ORDER_RESPONSE", "related_kp_ids": ["KP_ATC_401_TIME_RESPONSE"], "question_type": "CALCULATION", "stem_markdown": "标准欠阻尼二阶系统的 $\\zeta=0.5$、$\\omega_n=4\\,rad/s$。估算最大超调量和2%调节时间。", "answer_document": {"maximum_overshoot_ratio": 0.163, "settling_time_seconds": 2.0, "approximation": "2-percent criterion"}, "solution_markdown": "由 $M_p=e^{-\\pi\\zeta/\\sqrt{1-\\zeta^2}}$ 得 $M_p\\approx0.163$；由 $t_s\\approx4/(\\zeta\\omega_n)$ 得 $t_s\\approx2.0s$。", "difficulty_level": 3, "discrimination": 0.75, "diagnostic_tags": ["damping-ratio", "overshoot", "settling-time"], "misconception_ids": ["MISCONCEPTION_ATC_POLE_TAU_SIGN"], "authority_sources": [{"source_id": "TEXTBOOK_HU_AUTOMATIC_CONTROL_7E", "source_version": "7", "locator": "chapter:3"}], "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.golden-question.v1", "question_id": "QUESTION_ATC_ROUTH_001", "primary_kp_id": "KP_ATC_502_ROUTH_HURWITZ", "related_kp_ids": ["KP_ATC_501_STABILITY_CONCEPT"], "question_type": "CALCULATION", "stem_markdown": "特征多项式为 $D(s)=s^3+2s^2+3s+K$。用劳斯判据求系统渐近稳定的 $K$ 范围。", "answer_document": {"parameter": "K", "stable_interval": "0<K<6"}, "solution_markdown": "劳斯表首列为 $1,2,(6-K)/2,K$。首列全正要求 $K>0$ 且 $6-K>0$，因此 $0<K<6$。", "difficulty_level": 3, "discrimination": 0.8, "diagnostic_tags": ["routh-array", "parameter-range"], "misconception_ids": ["MISCONCEPTION_ATC_ROUTH_ZERO_ROW"], "authority_sources": [{"source_id": "TEXTBOOK_HU_AUTOMATIC_CONTROL_7E", "source_version": "7", "locator": "chapter:4"}], "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.golden-question.v1", "question_id": "QUESTION_ATC_NYQUIST_001", "primary_kp_id": "KP_ATC_602_NYQUIST_STABILITY", "related_kp_ids": ["KP_ATC_501_STABILITY_CONCEPT", "KP_ATC_601_FREQUENCY_RESPONSE"], "question_type": "PROOF", "stem_markdown": "采用课程约定：$N$ 为奈奎斯特曲线对 $-1+j0$ 点的顺时针环绕次数。若开环右半平面极点数 $P=1$，闭环稳定时 $N$ 应取何值？", "answer_document": {"P": 1, "Z": 0, "N": 1, "convention": "clockwise positive; Z=P-N"}, "solution_markdown": "闭环稳定要求右半平面闭环极点数 $Z=0$。由约定下的 $Z=P-N$，得到 $N=P-Z=1$，即顺时针环绕一次。", "difficulty_level": 4, "discrimination": 0.82, "diagnostic_tags": ["nyquist", "encirclement", "sign-convention"], "misconception_ids": ["MISCONCEPTION_ATC_NYQUIST_SIGN"], "authority_sources": [{"source_id": "TEXTBOOK_HU_AUTOMATIC_CONTROL_7E", "source_version": "7", "locator": "chapter:5"}], "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.golden-question.v1", "question_id": "QUESTION_ATC_CONTROLLABILITY_001", "primary_kp_id": "KP_ATC_802_CONTROLLABILITY_OBSERVABILITY", "related_kp_ids": ["KP_ATC_801_STATE_SPACE"], "question_type": "CALCULATION", "stem_markdown": "给定 $A=[[0,1],[-2,-3]]$、$B=[[0],[1]]$。判断系统是否完全能控。", "answer_document": {"controllability_matrix": [[0, 1], [1, -3]], "determinant": -1, "rank": 2, "controllable": true}, "solution_markdown": "能控矩阵 $Q_c=[B,AB]=[[0,1],[1,-3]]$，其行列式为 $-1\\neq0$，秩为2，等于系统阶数，因此系统完全能控。", "difficulty_level": 3, "discrimination": 0.78, "diagnostic_tags": ["controllability-matrix", "rank"], "misconception_ids": [], "authority_sources": [{"source_id": "TEXTBOOK_HU_AUTOMATIC_CONTROL_7E", "source_version": "7", "locator": "chapter:7"}], "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"}
    ]
  }
