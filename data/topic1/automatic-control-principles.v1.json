    "misconceptions": [
      {"schema_version": "topic1.misconception.v1", "misconception_id": "MISCONCEPTION_ATC_TRANSFER_INITIAL", "kp_id": "KP_ATC_301_TRANSFER_FUNCTION", "title": "忽略传递函数的零初始条件", "description": "把含非零初始条件的输出响应直接除以输入变换并称为传递函数。", "trigger_pattern": "推导G(s)时保留初值项却仍写成Y(s)/U(s)。", "diagnosis_tags": ["initial-condition", "transfer-function"], "remediation_hint": "先明确传递函数定义采用零初始条件，再把初值响应单独处理。", "severity": "HIGH", "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.misconception.v1", "misconception_id": "MISCONCEPTION_ATC_POLE_TAU_SIGN", "kp_id": "KP_ATC_402_SECOND_ORDER_RESPONSE", "title": "极点符号与时间常数混淆", "description": "把负实极点数值直接作为正时间常数。", "trigger_pattern": "对极点p<0写出tau=p而不是tau=-1/p。", "diagnosis_tags": ["sign-error", "time-constant"], "remediation_hint": "把一阶因子规范化为tau*s+1，再读取tau。", "severity": "HIGH", "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.misconception.v1", "misconception_id": "MISCONCEPTION_ATC_ROUTH_ZERO_ROW", "kp_id": "KP_ATC_502_ROUTH_HURWITZ", "title": "劳斯表全零行处理错误", "description": "遇到全零行后继续按普通递推，导致稳定根数量判断失真。", "trigger_pattern": "未使用上一行构造辅助多项式并求导替换全零行。", "diagnosis_tags": ["routh-array", "zero-row"], "remediation_hint": "由全零行上一行构造辅助多项式，对其求导后替换全零行。", "severity": "CRITICAL", "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.misconception.v1", "misconception_id": "MISCONCEPTION_ATC_NYQUIST_SIGN", "kp_id": "KP_ATC_602_NYQUIST_STABILITY", "title": "奈奎斯特环绕方向符号错误", "description": "混淆顺时针和逆时针环绕的正负号，进而错误计算闭环右半平面极点数。", "trigger_pattern": "未先声明N的方向约定便直接套用Z=P-N。", "diagnosis_tags": ["nyquist", "encirclement", "sign-error"], "remediation_hint": "固定课程约定后，在每次判断中显式写出P、N和Z的定义。", "severity": "CRITICAL", "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"},
      {"schema_version": "topic1.misconception.v1", "misconception_id": "MISCONCEPTION_ATC_PID_EFFECT", "kp_id": "KP_ATC_701_PID_COMPENSATION", "title": "把PID三项作用绝对化", "description": "认为增加某一参数必然单调改善对应指标，忽略对象模型和参数耦合。", "trigger_pattern": "仅依据口诀调整参数，不复核稳定裕度、饱和和噪声放大。", "diagnosis_tags": ["pid", "parameter-coupling", "design"], "remediation_hint": "每次调整后同时检查稳定性、动态性能、执行器饱和和高频噪声。", "severity": "HIGH", "revision": 1, "created_at": "2026-07-15T00:00:00Z", "updated_at": "2026-07-15T00:00:00Z"}
