LIYAN_ENVIRONMENT=development
LIYAN_DATABASE_URL=postgresql+asyncpg://liyans_app:liyans-app-local-only@localhost:5432/liyans
LIYAN_DATABASE_MIGRATION_URL=postgresql+asyncpg://liyans_migrator:liyans-migrator-local-only@localhost:5432/liyans
LIYAN_OUTBOX_DISPATCHER_DATABASE_URL=postgresql+asyncpg://liyans_dispatcher:liyans-dispatcher-local-only@localhost:5432/liyans
LIYAN_OUTBOX_PUBLISHER_ENABLED=false
LIYAN_SERVICE_INSTANCE_ID=liyans-api-local
LIYAN_IDEMPOTENCY_RETENTION_SECONDS=86400
LIYAN_IDEMPOTENCY_PROCESSING_LEASE_SECONDS=120
LIYAN_OUTBOX_CLAIM_LEASE_SECONDS=30
LIYAN_SSE_EVENT_RETENTION_SECONDS=86400
LIYAN_SSE_EVENT_MAX_BYTES=262144
LIYAN_SSE_NOTIFICATION_ENABLED=false
# Optional dedicated LISTEN connection; defaults to LIYAN_DATABASE_URL when omitted.
LIYAN_SSE_NOTIFICATION_DATABASE_URL=
LIYAN_SSE_NOTIFICATION_QUEUE_SIZE=1024
LIYAN_SSE_NOTIFICATION_RECONNECT_BASE_SECONDS=0.25
LIYAN_SSE_NOTIFICATION_RECONNECT_MAX_SECONDS=10
LIYAN_SSE_NOTIFICATION_STARTUP_TIMEOUT_SECONDS=5
LIYAN_OIDC_ISSUER=
LIYAN_OIDC_AUDIENCE=
LIYAN_OIDC_JWKS_URL=
LIYAN_OIDC_ALGORITHMS=["RS256"]
LIYAN_OIDC_TENANT_CLAIM=tenant_id
LIYAN_OIDC_ROLES_CLAIM=roles
LIYAN_OIDC_SCOPE_CLAIM=scope
LIYAN_OIDC_CLOCK_SKEW_SECONDS=30
LIYAN_OIDC_MAX_TOKEN_LIFETIME_SECONDS=3600
LIYAN_OIDC_JWKS_CACHE_TTL_SECONDS=300
LIYAN_OIDC_HTTP_TIMEOUT_SECONDS=3
LIYAN_ARTIFACT_ROOT=./var/artifacts
LIYAN_AUDIT_LOG_PATH=./var/audit/events.jsonl
LIYAN_SSE_CURSOR_SECRET=replace-with-at-least-32-random-bytes

# Providers remain disabled until endpoint, account ownership, quota, and
# contract compatibility have been validated in the provider smoke suite.
LIYAN_PROVIDER_EXTERNAL_ENABLED=false
LIYAN_PROVIDER_HTTP_TIMEOUT_SECONDS=90
LIYAN_PROVIDER_MAX_CONNECTIONS=32

LIYAN_SPARK_TEXT_ENDPOINT=
LIYAN_SPARK_TEXT_API_KEY=
LIYAN_SPARK_TEXT_MODEL_ALIAS=spark-text-approved

LIYAN_XFYUN_CODE_ENDPOINT=
LIYAN_XFYUN_CODE_API_KEY=
LIYAN_XFYUN_CODE_MODEL_ALIAS=xfyun-code-approved

LIYAN_SEEDANCE_ENDPOINT=
LIYAN_SEEDANCE_API_KEY=
LIYAN_SEEDANCE_MODEL_ALIAS=seedance-approved
