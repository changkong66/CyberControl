{
  "$defs": {
    "ArtifactObjectRefV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "artifact.object.ref.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "storage_namespace": {
          "const": "verification-artifacts",
          "title": "Storage Namespace",
          "type": "string"
        },
        "object_key": {
          "maxLength": 512,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9/_\\-.]{0,511}$",
          "title": "Object Key",
          "type": "string"
        },
        "media_type": {
          "enum": [
            "application/json",
            "application/x-ndjson",
            "text/markdown",
            "text/plain",
            "application/octet-stream"
          ],
          "title": "Media Type",
          "type": "string"
        },
        "content_encoding": {
          "enum": [
            "identity",
            "gzip"
          ],
          "title": "Content Encoding",
          "type": "string"
        },
        "byte_size": {
          "maximum": 33554432,
          "minimum": 1,
          "title": "Byte Size",
          "type": "integer"
        },
        "sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "storage_namespace",
        "object_key",
        "media_type",
        "content_encoding",
        "byte_size",
        "sha256",
        "created_at"
      ],
      "title": "ArtifactObjectRefV1",
      "type": "object"
    },
    "VerificationModule": {
      "enum": [
        "C2_RAG",
        "C3_ACADEMIC",
        "C4_GRAPH",
        "C5_QUIZ",
        "C6_CODE",
        "C7_EXTENSION",
        "C9_SECURITY",
        "C10_PRIVACY",
        "C11_COMPLIANCE"
      ],
      "title": "VerificationModule",
      "type": "string"
    },
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "module-run.result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "module_result_id": {
      "format": "uuid",
      "title": "Module Result Id",
      "type": "string"
    },
    "module_run_id": {
      "format": "uuid",
      "title": "Module Run Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "module": {
      "$ref": "#/$defs/VerificationModule"
    },
    "verdict": {
      "$ref": "#/$defs/VerificationVerdict"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "evidence_ref_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 512,
      "title": "Evidence Ref Ids",
      "type": "array"
    },
    "finding_codes": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Z][A-Z0-9_.-]{0,127}$",
        "type": "string"
      },
      "maxItems": 128,
      "title": "Finding Codes",
      "type": "array"
    },
    "result_artifact": {
      "$ref": "#/$defs/ArtifactObjectRefV1"
    },
    "result_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Result Sha256",
      "type": "string"
    },
    "deterministic": {
      "title": "Deterministic",
      "type": "boolean"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "module_result_id",
    "module_run_id",
    "verification_id",
    "claim_id",
    "module",
    "verdict",
    "confidence",
    "result_artifact",
    "result_sha256",
    "deterministic"
  ],
  "title": "ModuleRunResultV1",
  "type": "object"
}
