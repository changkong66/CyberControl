{
  "$defs": {
    "StabilityConclusion": {
      "enum": [
        "STABLE",
        "UNSTABLE",
        "MARGINAL",
        "INDETERMINATE"
      ],
      "title": "StabilityConclusion",
      "type": "string"
    },
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "stability-check.result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "stability_check_result_id": {
      "format": "uuid",
      "title": "Stability Check Result Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "stability_model_id": {
      "format": "uuid",
      "title": "Stability Model Id",
      "type": "string"
    },
    "conclusion": {
      "$ref": "#/$defs/StabilityConclusion"
    },
    "method": {
      "enum": [
        "ROUTH_HURWITZ",
        "JURY",
        "ROOTS",
        "EIGENVALUES",
        "HYBRID"
      ],
      "title": "Method",
      "type": "string"
    },
    "poles": {
      "items": {
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Poles",
      "type": "array"
    },
    "criterion_values": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Criterion Values",
      "type": "object"
    },
    "counterexample": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Counterexample"
    },
    "verdict": {
      "$ref": "#/$defs/VerificationVerdict"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "stability_check_result_id",
    "verification_id",
    "claim_id",
    "stability_model_id",
    "conclusion",
    "method",
    "verdict",
    "confidence"
  ],
  "title": "StabilityCheckResultV1",
  "type": "object"
}
