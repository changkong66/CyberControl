{
  "$defs": {
    "TesterQuestionV1": {
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Question Id",
          "type": "string"
        },
        "question_type": {
          "enum": [
            "CONCEPT",
            "DISCRIMINATION",
            "CALCULATION",
            "ENGINEERING",
            "MISCONCEPTION"
          ],
          "title": "Question Type",
          "type": "string"
        },
        "difficulty": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Difficulty",
          "type": "number"
        },
        "target_kp_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 16,
          "minItems": 1,
          "title": "Target Kp Ids",
          "type": "array"
        },
        "prompt_markdown": {
          "maxLength": 8192,
          "minLength": 1,
          "title": "Prompt Markdown",
          "type": "string"
        },
        "standard_answer": {
          "maxLength": 8192,
          "minLength": 1,
          "title": "Standard Answer",
          "type": "string"
        },
        "solution_steps": {
          "items": {
            "type": "string"
          },
          "maxItems": 32,
          "minItems": 1,
          "title": "Solution Steps",
          "type": "array"
        },
        "misconception_diagnostics": {
          "items": {
            "type": "string"
          },
          "maxItems": 16,
          "title": "Misconception Diagnostics",
          "type": "array"
        },
        "score": {
          "exclusiveMinimum": 0.0,
          "maximum": 100.0,
          "title": "Score",
          "type": "number"
        }
      },
      "required": [
        "question_id",
        "question_type",
        "difficulty",
        "target_kp_ids",
        "prompt_markdown",
        "standard_answer",
        "solution_steps",
        "score"
      ],
      "title": "TesterQuestionV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "topic3.tester-content.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "title": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "total_score": {
      "exclusiveMinimum": 0.0,
      "maximum": 1000.0,
      "title": "Total Score",
      "type": "number"
    },
    "questions": {
      "items": {
        "$ref": "#/$defs/TesterQuestionV1"
      },
      "maxItems": 100,
      "minItems": 1,
      "title": "Questions",
      "type": "array"
    },
    "diagnostic_dimensions": {
      "items": {
        "type": "string"
      },
      "maxItems": 16,
      "minItems": 1,
      "title": "Diagnostic Dimensions",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "title",
    "total_score",
    "questions",
    "diagnostic_dimensions"
  ],
  "title": "TesterContentV1",
  "type": "object"
}
