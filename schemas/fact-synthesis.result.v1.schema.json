{
  "$defs": {
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "fact-synthesis.result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "fact_synthesis_result_id": {
      "format": "uuid",
      "title": "Fact Synthesis Result Id",
      "type": "string"
    },
    "fact_synthesis_request_id": {
      "format": "uuid",
      "title": "Fact Synthesis Request Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "verdict": {
      "$ref": "#/$defs/VerificationVerdict"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "supported_statement": {
      "anyOf": [
        {
          "maxLength": 32768,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Supported Statement"
    },
    "contradiction_summary": {
      "anyOf": [
        {
          "maxLength": 16384,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Contradiction Summary"
    },
    "evidence_ref_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 512,
      "title": "Evidence Ref Ids",
      "type": "array"
    },
    "provider_request_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Provider Request Id",
      "type": "string"
    },
    "provider_response_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Provider Response Sha256",
      "type": "string"
    },
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "fact_synthesis_result_id",
    "fact_synthesis_request_id",
    "verification_id",
    "claim_id",
    "verdict",
    "confidence",
    "provider_request_id",
    "provider_response_sha256",
    "completed_at"
  ],
  "title": "FactSynthesisResultV1",
  "type": "object"
}
