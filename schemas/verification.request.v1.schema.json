{
  "$defs": {
    "ArtifactObjectRefV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "artifact.object.ref.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "storage_namespace": {
          "const": "verification-artifacts",
          "title": "Storage Namespace",
          "type": "string"
        },
        "object_key": {
          "maxLength": 512,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9/_\\-.]{0,511}$",
          "title": "Object Key",
          "type": "string"
        },
        "media_type": {
          "enum": [
            "application/json",
            "application/x-ndjson",
            "text/markdown",
            "text/plain",
            "application/octet-stream"
          ],
          "title": "Media Type",
          "type": "string"
        },
        "content_encoding": {
          "enum": [
            "identity",
            "gzip"
          ],
          "title": "Content Encoding",
          "type": "string"
        },
        "byte_size": {
          "maximum": 33554432,
          "minimum": 1,
          "title": "Byte Size",
          "type": "integer"
        },
        "sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "storage_namespace",
        "object_key",
        "media_type",
        "content_encoding",
        "byte_size",
        "sha256",
        "created_at"
      ],
      "title": "ArtifactObjectRefV1",
      "type": "object"
    },
    "BlockSnapshotManifestItemV1": {
      "additionalProperties": false,
      "properties": {
        "block_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Block Id",
          "type": "string"
        },
        "block_type": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Block Type",
          "type": "string"
        },
        "ordinal": {
          "minimum": 0,
          "title": "Ordinal",
          "type": "integer"
        },
        "json_pointer": {
          "maxLength": 1024,
          "minLength": 1,
          "title": "Json Pointer",
          "type": "string"
        },
        "sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "byte_size": {
          "maximum": 16777216,
          "minimum": 0,
          "title": "Byte Size",
          "type": "integer"
        }
      },
      "required": [
        "block_id",
        "block_type",
        "ordinal",
        "json_pointer",
        "sha256",
        "byte_size"
      ],
      "title": "BlockSnapshotManifestItemV1",
      "type": "object"
    },
    "ResourceType": {
      "enum": [
        "Lecturer_Doc",
        "MindMap",
        "Gradient_Quiz",
        "Simulation_Code",
        "Extension_Material"
      ],
      "title": "ResourceType",
      "type": "string"
    },
    "SourceAgent": {
      "enum": [
        "Lecturer",
        "MindMap",
        "Tester",
        "CodeSandbox",
        "Extension"
      ],
      "title": "SourceAgent",
      "type": "string"
    },
    "SourceSnapshotRefV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "source.snapshot.ref.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "source_envelope_id": {
          "format": "uuid",
          "title": "Source Envelope Id",
          "type": "string"
        },
        "source_envelope_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Source Envelope Version",
          "type": "string"
        },
        "source_envelope_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Source Envelope Sha256",
          "type": "string"
        },
        "blueprint_id": {
          "format": "uuid",
          "title": "Blueprint Id",
          "type": "string"
        },
        "blueprint_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Blueprint Version",
          "type": "string"
        },
        "blueprint_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Blueprint Sha256",
          "type": "string"
        },
        "candidate_id": {
          "format": "uuid",
          "title": "Candidate Id",
          "type": "string"
        },
        "candidate_version": {
          "minimum": 1,
          "title": "Candidate Version",
          "type": "integer"
        },
        "candidate_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Candidate Sha256",
          "type": "string"
        },
        "source_agent": {
          "$ref": "#/$defs/SourceAgent"
        },
        "resource_type": {
          "$ref": "#/$defs/ResourceType"
        },
        "full_snapshot": {
          "$ref": "#/$defs/ArtifactObjectRefV1"
        },
        "block_manifest": {
          "items": {
            "$ref": "#/$defs/BlockSnapshotManifestItemV1"
          },
          "maxItems": 2048,
          "minItems": 1,
          "title": "Block Manifest",
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "source_envelope_id",
        "source_envelope_version",
        "source_envelope_sha256",
        "blueprint_id",
        "blueprint_version",
        "blueprint_sha256",
        "candidate_id",
        "candidate_version",
        "candidate_sha256",
        "source_agent",
        "resource_type",
        "full_snapshot",
        "block_manifest"
      ],
      "title": "SourceSnapshotRefV1",
      "type": "object"
    },
    "VerificationContextV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "verification.context.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "course_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Course Id",
          "type": "string"
        },
        "course_version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Course Version",
          "type": "string"
        },
        "target_kp_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Target Kp Id",
          "type": "string"
        },
        "locale": {
          "const": "zh-CN",
          "title": "Locale",
          "type": "string"
        },
        "subject_domain": {
          "const": "AUTOMATION",
          "title": "Subject Domain",
          "type": "string"
        },
        "profile_snapshot_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactObjectRefV1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "path_decision_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactObjectRefV1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "personalization_policy_digest": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Personalization Policy Digest",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "course_id",
        "course_version",
        "target_kp_id",
        "locale",
        "subject_domain",
        "personalization_policy_digest"
      ],
      "title": "VerificationContextV1",
      "type": "object"
    },
    "VerificationProfile": {
      "enum": [
        "STANDARD",
        "STRICT",
        "CODE_STRICT"
      ],
      "title": "VerificationProfile",
      "type": "string"
    },
    "VerificationTrigger": {
      "enum": [
        "INITIAL_GENERATION",
        "REVISION_REVERIFY",
        "MANUAL_REVERIFY",
        "KNOWLEDGE_BASE_REVALIDATION",
        "POLICY_REVALIDATION"
      ],
      "title": "VerificationTrigger",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "verification.request.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "idempotency_key": {
      "maxLength": 128,
      "minLength": 32,
      "pattern": "^[A-Za-z0-9:_\\-.]+$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "trigger": {
      "$ref": "#/$defs/VerificationTrigger"
    },
    "parent_verification_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Verification Id"
    },
    "source_snapshot_ref": {
      "$ref": "#/$defs/SourceSnapshotRefV1"
    },
    "context": {
      "$ref": "#/$defs/VerificationContextV1"
    },
    "requested_profile": {
      "$ref": "#/$defs/VerificationProfile"
    },
    "requested_optional_modules": {
      "items": {
        "type": "string"
      },
      "maxItems": 12,
      "title": "Requested Optional Modules",
      "type": "array"
    },
    "deadline_at": {
      "format": "date-time",
      "title": "Deadline At",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "verification_id",
    "idempotency_key",
    "trigger",
    "source_snapshot_ref",
    "context",
    "requested_profile",
    "deadline_at",
    "requested_at"
  ],
  "title": "VerificationRequestPayloadV1",
  "type": "object"
}
