{
  "$defs": {
    "DerivationStepV1": {
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "description": "Root trace propagated from Topic 3 ingestion.",
          "maxLength": 64,
          "minLength": 16,
          "pattern": "^[a-fA-F0-9]{16,64}$",
          "title": "Trace Id",
          "type": "string"
        },
        "tenant_id": {
          "description": "Trusted server-side tenant boundary.",
          "maxLength": 128,
          "minLength": 1,
          "title": "Tenant Id",
          "type": "string"
        },
        "version_cas": {
          "description": "Optimistic concurrency version.",
          "minimum": 1,
          "title": "Version Cas",
          "type": "integer"
        },
        "record_sha256": {
          "description": "Canonical immutable record digest.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Record Sha256",
          "type": "string"
        },
        "created_at": {
          "description": "UTC record creation time.",
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "immutable": {
          "const": true,
          "description": "Records are append-only once emitted.",
          "title": "Immutable",
          "type": "boolean"
        },
        "schema_version": {
          "const": "derivation-step.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "ordinal": {
          "minimum": 0,
          "title": "Ordinal",
          "type": "integer"
        },
        "formula_ir_id": {
          "format": "uuid",
          "title": "Formula Ir Id",
          "type": "string"
        },
        "rule_name": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Rule Name",
          "type": "string"
        },
        "valid_from_previous": {
          "title": "Valid From Previous",
          "type": "boolean"
        },
        "finding_code": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finding Code"
        }
      },
      "required": [
        "trace_id",
        "tenant_id",
        "version_cas",
        "record_sha256",
        "created_at",
        "immutable",
        "schema_version",
        "ordinal",
        "formula_ir_id",
        "rule_name",
        "valid_from_previous"
      ],
      "title": "DerivationStepV1",
      "type": "object"
    },
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "derivation-check.result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "derivation_check_result_id": {
      "format": "uuid",
      "title": "Derivation Check Result Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "steps": {
      "items": {
        "$ref": "#/$defs/DerivationStepV1"
      },
      "maxItems": 2048,
      "minItems": 1,
      "title": "Steps",
      "type": "array"
    },
    "first_invalid_ordinal": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "First Invalid Ordinal"
    },
    "conclusion_formula_ir_id": {
      "format": "uuid",
      "title": "Conclusion Formula Ir Id",
      "type": "string"
    },
    "verdict": {
      "$ref": "#/$defs/VerificationVerdict"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "derivation_check_result_id",
    "verification_id",
    "claim_id",
    "steps",
    "conclusion_formula_ir_id",
    "verdict",
    "confidence"
  ],
  "title": "DerivationCheckResultV1",
  "type": "object"
}
