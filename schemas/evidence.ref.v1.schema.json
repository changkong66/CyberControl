{
  "$defs": {
    "SourceAuthorityTier": {
      "enum": [
        "PRIMARY_STANDARD",
        "AUTHORITATIVE_TEXTBOOK",
        "PEER_REVIEWED",
        "OFFICIAL_DOCUMENTATION",
        "CURATED_INTERNAL"
      ],
      "title": "SourceAuthorityTier",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "evidence.ref.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "evidence_ref_id": {
      "format": "uuid",
      "title": "Evidence Ref Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "knowledge_base_version_id": {
      "format": "uuid",
      "title": "Knowledge Base Version Id",
      "type": "string"
    },
    "knowledge_chunk_id": {
      "format": "uuid",
      "title": "Knowledge Chunk Id",
      "type": "string"
    },
    "source_document_id": {
      "format": "uuid",
      "title": "Source Document Id",
      "type": "string"
    },
    "source_document_version_id": {
      "format": "uuid",
      "title": "Source Document Version Id",
      "type": "string"
    },
    "section_id": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Section Id",
      "type": "string"
    },
    "citation": {
      "maxLength": 4096,
      "minLength": 1,
      "title": "Citation",
      "type": "string"
    },
    "excerpt": {
      "maxLength": 8192,
      "minLength": 1,
      "title": "Excerpt",
      "type": "string"
    },
    "excerpt_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Excerpt Sha256",
      "type": "string"
    },
    "bm25_score": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bm25 Score"
    },
    "vector_score": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": -1.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Vector Score"
    },
    "graph_score": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Graph Score"
    },
    "formula_score": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Formula Score"
    },
    "fused_score": {
      "minimum": 0.0,
      "title": "Fused Score",
      "type": "number"
    },
    "source_authority_tier": {
      "$ref": "#/$defs/SourceAuthorityTier"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "evidence_ref_id",
    "verification_id",
    "claim_id",
    "knowledge_base_version_id",
    "knowledge_chunk_id",
    "source_document_id",
    "source_document_version_id",
    "section_id",
    "citation",
    "excerpt",
    "excerpt_sha256",
    "fused_score",
    "source_authority_tier"
  ],
  "title": "EvidenceRefV1",
  "type": "object"
}
