{
  "$defs": {
    "IdentityAccountStatus": {
      "enum": [
        "ACTIVE",
        "DISABLED",
        "RECONCILIATION_REQUIRED"
      ],
      "title": "IdentityAccountStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "account.profile.v1",
      "default": "account.profile.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "account_id": {
      "format": "uuid",
      "title": "Account Id",
      "type": "string"
    },
    "tenant_id": {
      "maxLength": 128,
      "minLength": 3,
      "title": "Tenant Id",
      "type": "string"
    },
    "subject_ref": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Subject Ref",
      "type": "string"
    },
    "display_name": {
      "maxLength": 255,
      "minLength": 1,
      "title": "Display Name",
      "type": "string"
    },
    "preferred_locale": {
      "pattern": "^(zh-CN|zh-TW|en-US)$",
      "title": "Preferred Locale",
      "type": "string"
    },
    "email_hint": {
      "anyOf": [
        {
          "maxLength": 320,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Email Hint"
    },
    "email_verified": {
      "title": "Email Verified",
      "type": "boolean"
    },
    "phone_hint": {
      "anyOf": [
        {
          "maxLength": 32,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Phone Hint"
    },
    "phone_verified": {
      "title": "Phone Verified",
      "type": "boolean"
    },
    "status": {
      "$ref": "#/$defs/IdentityAccountStatus"
    },
    "profile_version": {
      "minimum": 1,
      "title": "Profile Version",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "account_id",
    "tenant_id",
    "subject_ref",
    "display_name",
    "preferred_locale",
    "email_verified",
    "phone_verified",
    "status",
    "profile_version",
    "created_at",
    "updated_at"
  ],
  "title": "AccountProfileV1",
  "type": "object"
}
