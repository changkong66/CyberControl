{
  "$defs": {
    "CodeLanguage": {
      "enum": [
        "MATLAB",
        "PYTHON",
        "SIMULINK_SCRIPT",
        "IEC61131_ST",
        "C_MCU"
      ],
      "title": "CodeLanguage",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "sandbox-policy.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "sandbox_policy_id": {
      "format": "uuid",
      "title": "Sandbox Policy Id",
      "type": "string"
    },
    "language": {
      "$ref": "#/$defs/CodeLanguage"
    },
    "policy_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Policy Version",
      "type": "string"
    },
    "runtime_image_digest": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "title": "Runtime Image Digest",
      "type": "string"
    },
    "network_access": {
      "const": false,
      "title": "Network Access",
      "type": "boolean"
    },
    "root_filesystem_read_only": {
      "const": true,
      "title": "Root Filesystem Read Only",
      "type": "boolean"
    },
    "memory_limit_mb": {
      "maximum": 4096,
      "minimum": 16,
      "title": "Memory Limit Mb",
      "type": "integer"
    },
    "cpu_quota_millis": {
      "maximum": 60000,
      "minimum": 10,
      "title": "Cpu Quota Millis",
      "type": "integer"
    },
    "pids_limit": {
      "maximum": 1024,
      "minimum": 1,
      "title": "Pids Limit",
      "type": "integer"
    },
    "timeout_ms": {
      "maximum": 120000,
      "minimum": 100,
      "title": "Timeout Ms",
      "type": "integer"
    },
    "allowed_commands": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "title": "Allowed Commands",
      "type": "array"
    },
    "denied_commands": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "title": "Denied Commands",
      "type": "array"
    },
    "syscall_profile_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Syscall Profile Sha256",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "sandbox_policy_id",
    "language",
    "policy_version",
    "runtime_image_digest",
    "network_access",
    "root_filesystem_read_only",
    "memory_limit_mb",
    "cpu_quota_millis",
    "pids_limit",
    "timeout_ms",
    "syscall_profile_sha256"
  ],
  "title": "SandboxPolicyV1",
  "type": "object"
}
