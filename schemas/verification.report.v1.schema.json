{
  "$defs": {
    "AggregateDecision": {
      "enum": [
        "RELEASE",
        "RELEASE_WITH_DISCLOSURE",
        "REVISE",
        "REVIEW_REQUIRED",
        "BLOCK"
      ],
      "title": "AggregateDecision",
      "type": "string"
    },
    "ArtifactObjectRefV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "artifact.object.ref.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "storage_namespace": {
          "const": "verification-artifacts",
          "title": "Storage Namespace",
          "type": "string"
        },
        "object_key": {
          "maxLength": 512,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9/_\\-.]{0,511}$",
          "title": "Object Key",
          "type": "string"
        },
        "media_type": {
          "enum": [
            "application/json",
            "application/x-ndjson",
            "text/markdown",
            "text/plain",
            "application/octet-stream"
          ],
          "title": "Media Type",
          "type": "string"
        },
        "content_encoding": {
          "enum": [
            "identity",
            "gzip"
          ],
          "title": "Content Encoding",
          "type": "string"
        },
        "byte_size": {
          "maximum": 33554432,
          "minimum": 1,
          "title": "Byte Size",
          "type": "integer"
        },
        "sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "storage_namespace",
        "object_key",
        "media_type",
        "content_encoding",
        "byte_size",
        "sha256",
        "created_at"
      ],
      "title": "ArtifactObjectRefV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "verification.report.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "report_id": {
      "format": "uuid",
      "title": "Report Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "candidate_id": {
      "format": "uuid",
      "title": "Candidate Id",
      "type": "string"
    },
    "candidate_version": {
      "minimum": 1,
      "title": "Candidate Version",
      "type": "integer"
    },
    "candidate_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Candidate Sha256",
      "type": "string"
    },
    "knowledge_base_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Knowledge Base Version",
      "type": "string"
    },
    "aggregation_result_id": {
      "format": "uuid",
      "title": "Aggregation Result Id",
      "type": "string"
    },
    "decision": {
      "$ref": "#/$defs/AggregateDecision"
    },
    "claim_verdict_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 4096,
      "minItems": 1,
      "title": "Claim Verdict Ids",
      "type": "array"
    },
    "evidence_chain_manifest_id": {
      "format": "uuid",
      "title": "Evidence Chain Manifest Id",
      "type": "string"
    },
    "report_artifact": {
      "$ref": "#/$defs/ArtifactObjectRefV1"
    },
    "report_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Report Sha256",
      "type": "string"
    },
    "policy_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Policy Version",
      "type": "string"
    },
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "report_id",
    "verification_id",
    "candidate_id",
    "candidate_version",
    "candidate_sha256",
    "knowledge_base_version",
    "aggregation_result_id",
    "decision",
    "claim_verdict_ids",
    "evidence_chain_manifest_id",
    "report_artifact",
    "report_sha256",
    "policy_version",
    "completed_at"
  ],
  "title": "VerificationReportV1",
  "type": "object"
}
