{
  "$defs": {
    "Topic2ProfileDimension": {
      "enum": [
        "KNOWLEDGE_MASTERY",
        "PROBLEM_SOLVING_PROFICIENCY",
        "MISCONCEPTION_PREFERENCE",
        "LEARNING_PACE",
        "FORGETTING_RATE",
        "LEARNING_GOAL_TENDENCY"
      ],
      "title": "Topic2ProfileDimension",
      "type": "string"
    },
    "Topic2ProfileFeatureV1": {
      "additionalProperties": false,
      "description": "Evidence-backed feature supporting one six-dimensional profile snapshot.",
      "properties": {
        "schema_version": {
          "const": "topic2.profile-feature.v1",
          "default": "topic2.profile-feature.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "feature_id": {
          "format": "uuid",
          "title": "Feature Id",
          "type": "string"
        },
        "dimension": {
          "$ref": "#/$defs/Topic2ProfileDimension"
        },
        "feature_key": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Feature Key",
          "type": "string"
        },
        "value_document": {
          "additionalProperties": true,
          "title": "Value Document",
          "type": "object"
        },
        "normalized_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Normalized Score",
          "type": "number"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_count": {
          "minimum": 0,
          "title": "Evidence Count",
          "type": "integer"
        },
        "source_event_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 5000,
          "title": "Source Event Ids",
          "type": "array"
        },
        "computed_at": {
          "format": "date-time",
          "title": "Computed At",
          "type": "string"
        }
      },
      "required": [
        "feature_id",
        "dimension",
        "feature_key",
        "value_document",
        "normalized_score",
        "confidence",
        "evidence_count",
        "computed_at"
      ],
      "title": "Topic2ProfileFeatureV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Immutable profile aggregate, full evidence features, and audit binding.",
  "properties": {
    "schema_version": {
      "const": "topic2.student-profile.v1",
      "default": "topic2.student-profile.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "profile_id": {
      "format": "uuid",
      "title": "Profile Id",
      "type": "string"
    },
    "learner_ref": {
      "maxLength": 256,
      "minLength": 3,
      "title": "Learner Ref",
      "type": "string"
    },
    "course_id": {
      "maxLength": 64,
      "minLength": 3,
      "title": "Course Id",
      "type": "string"
    },
    "profile_version": {
      "minimum": 1,
      "title": "Profile Version",
      "type": "integer"
    },
    "parent_profile_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Profile Id"
    },
    "policy_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Policy Version",
      "type": "string"
    },
    "knowledge_mastery": {
      "maximum": 1,
      "minimum": 0,
      "title": "Knowledge Mastery",
      "type": "number"
    },
    "problem_solving_proficiency": {
      "maximum": 1,
      "minimum": 0,
      "title": "Problem Solving Proficiency",
      "type": "number"
    },
    "misconception_preference": {
      "maximum": 1,
      "minimum": 0,
      "title": "Misconception Preference",
      "type": "number"
    },
    "learning_pace": {
      "maximum": 1,
      "minimum": 0,
      "title": "Learning Pace",
      "type": "number"
    },
    "forgetting_rate": {
      "maximum": 1,
      "minimum": 0,
      "title": "Forgetting Rate",
      "type": "number"
    },
    "learning_goal_tendency": {
      "maximum": 1,
      "minimum": 0,
      "title": "Learning Goal Tendency",
      "type": "number"
    },
    "confidence_score": {
      "maximum": 1,
      "minimum": 0,
      "title": "Confidence Score",
      "type": "number"
    },
    "activity_count": {
      "minimum": 0,
      "title": "Activity Count",
      "type": "integer"
    },
    "last_event_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Event At"
    },
    "source_window_start": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Window Start"
    },
    "source_window_end": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Window End"
    },
    "profile_document": {
      "additionalProperties": true,
      "title": "Profile Document",
      "type": "object"
    },
    "content_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Content Sha256",
      "type": "string"
    },
    "frozen_at": {
      "format": "date-time",
      "title": "Frozen At",
      "type": "string"
    },
    "features": {
      "items": {
        "$ref": "#/$defs/Topic2ProfileFeatureV1"
      },
      "maxItems": 10000,
      "minItems": 6,
      "title": "Features",
      "type": "array"
    },
    "audit_event_id": {
      "format": "uuid",
      "title": "Audit Event Id",
      "type": "string"
    },
    "created_by_subject": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Created By Subject",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    }
  },
  "required": [
    "profile_id",
    "learner_ref",
    "course_id",
    "profile_version",
    "policy_version",
    "knowledge_mastery",
    "problem_solving_proficiency",
    "misconception_preference",
    "learning_pace",
    "forgetting_rate",
    "learning_goal_tendency",
    "confidence_score",
    "activity_count",
    "profile_document",
    "content_sha256",
    "frozen_at",
    "features",
    "audit_event_id",
    "created_by_subject",
    "created_at"
  ],
  "title": "Topic2StudentProfileV1",
  "type": "object"
}
