{
  "$defs": {
    "AgentTaskState": {
      "enum": [
        "PENDING",
        "RUNNING",
        "SUCCEEDED",
        "FAILED",
        "SKIPPED",
        "CANCELLED"
      ],
      "title": "AgentTaskState",
      "type": "string"
    },
    "BlockStatus": {
      "enum": [
        "COMPLETE",
        "FAILED",
        "SUPERSEDED"
      ],
      "title": "BlockStatus",
      "type": "string"
    },
    "BlockType": {
      "enum": [
        "MARKDOWN",
        "MERMAID",
        "QUIZ",
        "CODE",
        "EXTENSION",
        "METADATA"
      ],
      "title": "BlockType",
      "type": "string"
    },
    "BlockV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "topic3.block.v1",
          "description": "Frozen wrapper version shared by all Topic 3 block types.",
          "title": "Schema Version",
          "type": "string"
        },
        "block_id": {
          "description": "Stable block identity generated by the owning agent.",
          "maxLength": 128,
          "minLength": 1,
          "title": "Block Id",
          "type": "string"
        },
        "block_type": {
          "$ref": "#/$defs/BlockType",
          "description": "Rendering and validation family for the opaque block content."
        },
        "ordinal": {
          "description": "Zero-based order inside the candidate; ordinals must be contiguous.",
          "minimum": 0,
          "title": "Ordinal",
          "type": "integer"
        },
        "title": {
          "anyOf": [
            {
              "maxLength": 256,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional student-visible title supplied by the owning agent.",
          "title": "Title"
        },
        "content_schema_version": {
          "description": "Owning agent payload schema version for the content object.",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Content Schema Version",
          "type": "string"
        },
        "content": {
          "additionalProperties": true,
          "description": "Frozen agent-specific content. Infrastructure must not rewrite it.",
          "title": "Content",
          "type": "object"
        },
        "content_sha256": {
          "description": "SHA-256 of canonical content JSON, excluding wrapper metadata.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Sha256",
          "type": "string"
        },
        "dependency_block_ids": {
          "description": "Candidate-local block dependencies used for ordering and validation.",
          "items": {
            "type": "string"
          },
          "maxItems": 128,
          "title": "Dependency Block Ids",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/BlockStatus",
          "description": "Generation status of this exact block version."
        },
        "created_at": {
          "description": "UTC block completion time from the owning agent.",
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "block_id",
        "block_type",
        "ordinal",
        "content_schema_version",
        "content",
        "content_sha256",
        "status",
        "created_at"
      ],
      "title": "BlockV1",
      "type": "object"
    },
    "CandidateProvenanceV1": {
      "additionalProperties": false,
      "properties": {
        "agent": {
          "$ref": "#/$defs/SourceAgent",
          "description": "Owning Topic 3 generation agent."
        },
        "agent_build_version": {
          "description": "Owning agent build version used to generate the candidate.",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Agent Build Version",
          "type": "string"
        },
        "prompt_bundle_version": {
          "description": "Frozen prompt bundle selected by the blueprint.",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Prompt Bundle Version",
          "type": "string"
        },
        "provider_alias": {
          "description": "Approved provider alias or local deterministic producer.",
          "enum": [
            "spark_text",
            "xfyun_code",
            "seedance",
            "local"
          ],
          "title": "Provider Alias",
          "type": "string"
        },
        "provider_request_ids": {
          "description": "Provider request identities retained for audit without credentials.",
          "items": {
            "type": "string"
          },
          "maxItems": 256,
          "title": "Provider Request Ids",
          "type": "array"
        }
      },
      "required": [
        "agent",
        "agent_build_version",
        "prompt_bundle_version",
        "provider_alias"
      ],
      "title": "CandidateProvenanceV1",
      "type": "object"
    },
    "CandidateStatus": {
      "enum": [
        "GENERATING",
        "COMPLETE",
        "FAILED",
        "SUPERSEDED"
      ],
      "title": "CandidateStatus",
      "type": "string"
    },
    "CandidateV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "topic3.candidate.v1",
          "description": "Frozen candidate wrapper version.",
          "title": "Schema Version",
          "type": "string"
        },
        "candidate_id": {
          "description": "Logical candidate identity preserved across revision versions.",
          "format": "uuid",
          "title": "Candidate Id",
          "type": "string"
        },
        "candidate_version": {
          "description": "Monotonically increasing candidate version.",
          "minimum": 1,
          "title": "Candidate Version",
          "type": "integer"
        },
        "parent_candidate_version": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Previous version when produced by a revision; null for version one.",
          "title": "Parent Candidate Version"
        },
        "blueprint_id": {
          "description": "Immutable Blueprint identity that authorized generation.",
          "format": "uuid",
          "title": "Blueprint Id",
          "type": "string"
        },
        "blueprint_version": {
          "description": "Exact Blueprint version bound to this candidate.",
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Blueprint Version",
          "type": "string"
        },
        "blueprint_sha256": {
          "description": "Canonical Blueprint hash used to detect drift.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Blueprint Sha256",
          "type": "string"
        },
        "resource_type": {
          "$ref": "#/$defs/ResourceType",
          "description": "Resource family owned by the generating agent."
        },
        "status": {
          "$ref": "#/$defs/CandidateStatus",
          "description": "Lifecycle status of this exact candidate version."
        },
        "blocks": {
          "description": "Ordered immutable blocks produced by the agent.",
          "items": {
            "$ref": "#/$defs/BlockV1"
          },
          "maxItems": 2048,
          "minItems": 1,
          "title": "Blocks",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/CandidateProvenanceV1",
          "description": "Agent, prompt, provider, and request provenance."
        },
        "personalization_policy_digest": {
          "description": "Hash of the frozen Topic 2 personalization input used by generation.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Personalization Policy Digest",
          "type": "string"
        },
        "candidate_sha256": {
          "description": "SHA-256 of the canonical candidate excluding this field.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Candidate Sha256",
          "type": "string"
        },
        "created_at": {
          "description": "UTC completion time of this candidate version.",
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "candidate_id",
        "candidate_version",
        "blueprint_id",
        "blueprint_version",
        "blueprint_sha256",
        "resource_type",
        "status",
        "blocks",
        "provenance",
        "personalization_policy_digest",
        "candidate_sha256",
        "created_at"
      ],
      "title": "CandidateV1",
      "type": "object"
    },
    "GenerationSessionState": {
      "enum": [
        "PLANNED",
        "RUNNING",
        "COMPLETED",
        "PARTIAL",
        "FAILED",
        "CANCELLED"
      ],
      "title": "GenerationSessionState",
      "type": "string"
    },
    "ResourceType": {
      "enum": [
        "Lecturer_Doc",
        "MindMap",
        "Gradient_Quiz",
        "Simulation_Code",
        "Extension_Material"
      ],
      "title": "ResourceType",
      "type": "string"
    },
    "SourceAgent": {
      "enum": [
        "Lecturer",
        "MindMap",
        "Tester",
        "CodeSandbox",
        "Extension"
      ],
      "title": "SourceAgent",
      "type": "string"
    },
    "Topic3AgentTaskSnapshotV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "topic3.agent-task-snapshot.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "task_id": {
          "format": "uuid",
          "title": "Task Id",
          "type": "string"
        },
        "task_version": {
          "minimum": 1,
          "title": "Task Version",
          "type": "integer"
        },
        "blueprint_id": {
          "format": "uuid",
          "title": "Blueprint Id",
          "type": "string"
        },
        "blueprint_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Blueprint Version",
          "type": "string"
        },
        "agent": {
          "$ref": "#/$defs/SourceAgent"
        },
        "resource_type": {
          "$ref": "#/$defs/ResourceType"
        },
        "state": {
          "$ref": "#/$defs/AgentTaskState"
        },
        "attempt": {
          "maximum": 8,
          "minimum": 0,
          "title": "Attempt",
          "type": "integer"
        },
        "max_attempts": {
          "maximum": 8,
          "minimum": 1,
          "title": "Max Attempts",
          "type": "integer"
        },
        "request_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Request Sha256",
          "type": "string"
        },
        "result_sha256": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result Sha256"
        },
        "candidate_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Id"
        },
        "candidate_version": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Version"
        },
        "error_code": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Code"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        }
      },
      "required": [
        "schema_version",
        "task_id",
        "task_version",
        "blueprint_id",
        "blueprint_version",
        "agent",
        "resource_type",
        "state",
        "attempt",
        "max_attempts",
        "request_sha256"
      ],
      "title": "Topic3AgentTaskSnapshotV1",
      "type": "object"
    },
    "Topic3BlueprintStepV1": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "topic3.blueprint-step.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "task_id": {
          "format": "uuid",
          "title": "Task Id",
          "type": "string"
        },
        "ordinal": {
          "maximum": 4,
          "minimum": 0,
          "title": "Ordinal",
          "type": "integer"
        },
        "agent": {
          "$ref": "#/$defs/SourceAgent"
        },
        "resource_type": {
          "$ref": "#/$defs/ResourceType"
        },
        "dependency_task_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 4,
          "title": "Dependency Task Ids",
          "type": "array"
        },
        "provider_alias": {
          "enum": [
            "spark_text",
            "xfyun_code",
            "seedance",
            "local"
          ],
          "title": "Provider Alias",
          "type": "string"
        },
        "prompt_bundle_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Prompt Bundle Version",
          "type": "string"
        },
        "timeout_seconds": {
          "maximum": 120.0,
          "minimum": 1.0,
          "title": "Timeout Seconds",
          "type": "number"
        },
        "max_attempts": {
          "default": 3,
          "maximum": 8,
          "minimum": 1,
          "title": "Max Attempts",
          "type": "integer"
        },
        "activation_reasons": {
          "items": {
            "type": "string"
          },
          "maxItems": 16,
          "minItems": 1,
          "title": "Activation Reasons",
          "type": "array"
        }
      },
      "required": [
        "schema_version",
        "task_id",
        "ordinal",
        "agent",
        "resource_type",
        "provider_alias",
        "prompt_bundle_version",
        "timeout_seconds",
        "activation_reasons"
      ],
      "title": "Topic3BlueprintStepV1",
      "type": "object"
    },
    "Topic3ExecutionBlueprintV1": {
      "additionalProperties": false,
      "description": "Immutable, replayable execution plan selected from frozen Topic 1/2 inputs.",
      "properties": {
        "schema_version": {
          "const": "topic3.execution-blueprint.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "blueprint_id": {
          "format": "uuid",
          "title": "Blueprint Id",
          "type": "string"
        },
        "blueprint_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Blueprint Version",
          "type": "string"
        },
        "generation_session_id": {
          "format": "uuid",
          "title": "Generation Session Id",
          "type": "string"
        },
        "generation_session_version": {
          "minimum": 1,
          "title": "Generation Session Version",
          "type": "integer"
        },
        "topic1_graph_snapshot_id": {
          "format": "uuid",
          "title": "Topic1 Graph Snapshot Id",
          "type": "string"
        },
        "topic1_graph_version": {
          "minimum": 1,
          "title": "Topic1 Graph Version",
          "type": "integer"
        },
        "topic1_graph_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Topic1 Graph Sha256",
          "type": "string"
        },
        "topic2_profile_id": {
          "format": "uuid",
          "title": "Topic2 Profile Id",
          "type": "string"
        },
        "topic2_profile_version": {
          "minimum": 1,
          "title": "Topic2 Profile Version",
          "type": "integer"
        },
        "topic2_path_snapshot_id": {
          "format": "uuid",
          "title": "Topic2 Path Snapshot Id",
          "type": "string"
        },
        "topic2_path_version": {
          "minimum": 1,
          "title": "Topic2 Path Version",
          "type": "integer"
        },
        "personalization_policy_digest": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Personalization Policy Digest",
          "type": "string"
        },
        "target_kp_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 128,
          "minItems": 1,
          "title": "Target Kp Ids",
          "type": "array"
        },
        "max_parallelism": {
          "maximum": 5,
          "minimum": 1,
          "title": "Max Parallelism",
          "type": "integer"
        },
        "allow_partial": {
          "title": "Allow Partial",
          "type": "boolean"
        },
        "activation_policy_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Activation Policy Version",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/Topic3BlueprintStepV1"
          },
          "maxItems": 5,
          "minItems": 1,
          "title": "Steps",
          "type": "array"
        },
        "blueprint_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Blueprint Sha256",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "blueprint_id",
        "blueprint_version",
        "generation_session_id",
        "generation_session_version",
        "topic1_graph_snapshot_id",
        "topic1_graph_version",
        "topic1_graph_sha256",
        "topic2_profile_id",
        "topic2_profile_version",
        "topic2_path_snapshot_id",
        "topic2_path_version",
        "personalization_policy_digest",
        "target_kp_ids",
        "max_parallelism",
        "allow_partial",
        "activation_policy_version",
        "steps",
        "blueprint_sha256",
        "created_at"
      ],
      "title": "Topic3ExecutionBlueprintV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "topic3.generation-result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "generation_session_id": {
      "format": "uuid",
      "title": "Generation Session Id",
      "type": "string"
    },
    "session_version": {
      "minimum": 1,
      "title": "Session Version",
      "type": "integer"
    },
    "state": {
      "$ref": "#/$defs/GenerationSessionState"
    },
    "blueprint": {
      "$ref": "#/$defs/Topic3ExecutionBlueprintV1"
    },
    "tasks": {
      "items": {
        "$ref": "#/$defs/Topic3AgentTaskSnapshotV1"
      },
      "maxItems": 64,
      "minItems": 1,
      "title": "Tasks",
      "type": "array"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/CandidateV1"
      },
      "maxItems": 64,
      "title": "Candidates",
      "type": "array"
    },
    "failed_agents": {
      "items": {
        "$ref": "#/$defs/SourceAgent"
      },
      "maxItems": 5,
      "title": "Failed Agents",
      "type": "array"
    },
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "generation_session_id",
    "session_version",
    "state",
    "blueprint",
    "tasks",
    "completed_at"
  ],
  "title": "Topic3GenerationResultV1",
  "type": "object"
}
