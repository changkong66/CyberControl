{
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "embedding-profile.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "embedding_profile_id": {
      "format": "uuid",
      "title": "Embedding Profile Id",
      "type": "string"
    },
    "algorithm": {
      "const": "HASHED_LEXICAL_2048",
      "title": "Algorithm",
      "type": "string"
    },
    "dimension": {
      "const": 2048,
      "title": "Dimension",
      "type": "integer"
    },
    "tokenizer_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Tokenizer Version",
      "type": "string"
    },
    "hash_seed_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Hash Seed Version",
      "type": "string"
    },
    "normalization": {
      "const": "L2",
      "title": "Normalization",
      "type": "string"
    },
    "signed_hashing": {
      "const": true,
      "title": "Signed Hashing",
      "type": "boolean"
    },
    "network_access": {
      "const": false,
      "title": "Network Access",
      "type": "boolean"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "embedding_profile_id",
    "algorithm",
    "dimension",
    "tokenizer_version",
    "hash_seed_version",
    "normalization",
    "signed_hashing",
    "network_access"
  ],
  "title": "EmbeddingProfileV1",
  "type": "object"
}
