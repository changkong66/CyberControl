{
  "$defs": {
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "claim.verdict.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "claim_verdict_id": {
      "format": "uuid",
      "title": "Claim Verdict Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "verdict": {
      "$ref": "#/$defs/VerificationVerdict"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "module_result_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 32,
      "minItems": 1,
      "title": "Module Result Ids",
      "type": "array"
    },
    "evidence_ref_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 1024,
      "title": "Evidence Ref Ids",
      "type": "array"
    },
    "reason_codes": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Z][A-Z0-9_.-]{0,127}$",
        "type": "string"
      },
      "maxItems": 128,
      "title": "Reason Codes",
      "type": "array"
    },
    "disclosure_codes": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Z][A-Z0-9_.-]{0,127}$",
        "type": "string"
      },
      "maxItems": 32,
      "title": "Disclosure Codes",
      "type": "array"
    },
    "non_waivable": {
      "title": "Non Waivable",
      "type": "boolean"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "claim_verdict_id",
    "verification_id",
    "claim_id",
    "verdict",
    "confidence",
    "module_result_ids",
    "non_waivable"
  ],
  "title": "ClaimVerdictV1",
  "type": "object"
}
