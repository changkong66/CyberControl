{
  "$defs": {
    "Topic2LearningPathRecordV1": {
      "additionalProperties": false,
      "description": "Persisted path snapshot, its change explanation, and audit provenance.",
      "properties": {
        "schema_version": {
          "const": "topic2.learning-path-record.v1",
          "default": "topic2.learning-path-record.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "snapshot": {
          "$ref": "#/$defs/Topic2LearningPathSnapshotV1"
        },
        "change": {
          "$ref": "#/$defs/Topic2PathChangeV1"
        },
        "audit_event_id": {
          "format": "uuid",
          "title": "Audit Event Id",
          "type": "string"
        },
        "created_by_subject": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Created By Subject",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "snapshot",
        "change",
        "audit_event_id",
        "created_by_subject",
        "created_at"
      ],
      "title": "Topic2LearningPathRecordV1",
      "type": "object"
    },
    "Topic2LearningPathSnapshotV1": {
      "additionalProperties": false,
      "description": "Immutable path snapshot bound to exact Topic 1 graph and profile versions.",
      "properties": {
        "schema_version": {
          "const": "topic2.learning-path-snapshot.v1",
          "default": "topic2.learning-path-snapshot.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "path_snapshot_id": {
          "format": "uuid",
          "title": "Path Snapshot Id",
          "type": "string"
        },
        "learner_ref": {
          "maxLength": 256,
          "minLength": 3,
          "title": "Learner Ref",
          "type": "string"
        },
        "course_id": {
          "maxLength": 64,
          "minLength": 3,
          "title": "Course Id",
          "type": "string"
        },
        "path_version": {
          "minimum": 1,
          "title": "Path Version",
          "type": "integer"
        },
        "parent_path_snapshot_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Path Snapshot Id"
        },
        "topic1_graph_snapshot_id": {
          "format": "uuid",
          "title": "Topic1 Graph Snapshot Id",
          "type": "string"
        },
        "topic1_graph_version": {
          "minimum": 1,
          "title": "Topic1 Graph Version",
          "type": "integer"
        },
        "profile_id": {
          "format": "uuid",
          "title": "Profile Id",
          "type": "string"
        },
        "plan_type": {
          "$ref": "#/$defs/Topic2PathPlanType"
        },
        "trigger_reason": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Trigger Reason",
          "type": "string"
        },
        "target_goal": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Target Goal",
          "type": "string"
        },
        "policy_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Policy Version",
          "type": "string"
        },
        "path_document": {
          "additionalProperties": true,
          "title": "Path Document",
          "type": "object"
        },
        "decision_document": {
          "additionalProperties": true,
          "title": "Decision Document",
          "type": "object"
        },
        "node_count": {
          "maximum": 500,
          "minimum": 0,
          "title": "Node Count",
          "type": "integer"
        },
        "estimated_minutes": {
          "maximum": 1200000,
          "minimum": 0,
          "title": "Estimated Minutes",
          "type": "integer"
        },
        "manual_override": {
          "title": "Manual Override",
          "type": "boolean"
        },
        "content_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Sha256",
          "type": "string"
        },
        "frozen_at": {
          "format": "date-time",
          "title": "Frozen At",
          "type": "string"
        }
      },
      "required": [
        "path_snapshot_id",
        "learner_ref",
        "course_id",
        "path_version",
        "topic1_graph_snapshot_id",
        "topic1_graph_version",
        "profile_id",
        "plan_type",
        "trigger_reason",
        "target_goal",
        "policy_version",
        "path_document",
        "decision_document",
        "node_count",
        "estimated_minutes",
        "manual_override",
        "content_sha256",
        "frozen_at"
      ],
      "title": "Topic2LearningPathSnapshotV1",
      "type": "object"
    },
    "Topic2MemoryRiskLevel": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ],
      "title": "Topic2MemoryRiskLevel",
      "type": "string"
    },
    "Topic2MemoryStateV1": {
      "additionalProperties": false,
      "description": "Versioned exponential-forgetting state for one Topic 1 knowledge point.",
      "properties": {
        "schema_version": {
          "const": "topic2.memory-state.v1",
          "default": "topic2.memory-state.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "memory_state_id": {
          "format": "uuid",
          "title": "Memory State Id",
          "type": "string"
        },
        "learner_ref": {
          "maxLength": 256,
          "minLength": 3,
          "title": "Learner Ref",
          "type": "string"
        },
        "course_id": {
          "maxLength": 64,
          "minLength": 3,
          "title": "Course Id",
          "type": "string"
        },
        "kp_id": {
          "maxLength": 120,
          "minLength": 6,
          "title": "Kp Id",
          "type": "string"
        },
        "state_version": {
          "minimum": 1,
          "title": "State Version",
          "type": "integer"
        },
        "parent_memory_state_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Memory State Id"
        },
        "model_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Model Version",
          "type": "string"
        },
        "stability_days": {
          "exclusiveMinimum": 0,
          "maximum": 36500,
          "title": "Stability Days",
          "type": "number"
        },
        "effective_stability_days": {
          "exclusiveMinimum": 0,
          "maximum": 36500,
          "title": "Effective Stability Days",
          "type": "number"
        },
        "elapsed_days": {
          "minimum": 0,
          "title": "Elapsed Days",
          "type": "number"
        },
        "retrievability": {
          "maximum": 1,
          "minimum": 0,
          "title": "Retrievability",
          "type": "number"
        },
        "forgetting_rate": {
          "maximum": 1,
          "minimum": 0,
          "title": "Forgetting Rate",
          "type": "number"
        },
        "difficulty_factor": {
          "maximum": 4,
          "minimum": 0.25,
          "title": "Difficulty Factor",
          "type": "number"
        },
        "review_gain": {
          "maximum": 16,
          "minimum": 0,
          "title": "Review Gain",
          "type": "number"
        },
        "review_count": {
          "minimum": 0,
          "title": "Review Count",
          "type": "integer"
        },
        "lapse_count": {
          "minimum": 0,
          "title": "Lapse Count",
          "type": "integer"
        },
        "last_reviewed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Reviewed At"
        },
        "last_activity_at": {
          "format": "date-time",
          "title": "Last Activity At",
          "type": "string"
        },
        "next_review_at": {
          "format": "date-time",
          "title": "Next Review At",
          "type": "string"
        },
        "risk_level": {
          "$ref": "#/$defs/Topic2MemoryRiskLevel"
        },
        "model_parameters": {
          "additionalProperties": true,
          "title": "Model Parameters",
          "type": "object"
        },
        "content_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Sha256",
          "type": "string"
        },
        "computed_at": {
          "format": "date-time",
          "title": "Computed At",
          "type": "string"
        },
        "audit_event_id": {
          "format": "uuid",
          "title": "Audit Event Id",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "memory_state_id",
        "learner_ref",
        "course_id",
        "kp_id",
        "state_version",
        "model_version",
        "stability_days",
        "effective_stability_days",
        "elapsed_days",
        "retrievability",
        "forgetting_rate",
        "difficulty_factor",
        "review_gain",
        "review_count",
        "lapse_count",
        "last_activity_at",
        "next_review_at",
        "risk_level",
        "model_parameters",
        "content_sha256",
        "computed_at",
        "audit_event_id",
        "created_at"
      ],
      "title": "Topic2MemoryStateV1",
      "type": "object"
    },
    "Topic2PathChangeType": {
      "enum": [
        "INITIALIZED",
        "MEMORY_RISK",
        "MASTERY_DEFICIT",
        "MISCONCEPTION",
        "GOAL_CHANGED",
        "MANUAL_OVERRIDE",
        "TOPOLOGY_REPAIRED",
        "RESTORED"
      ],
      "title": "Topic2PathChangeType",
      "type": "string"
    },
    "Topic2PathChangeV1": {
      "additionalProperties": false,
      "description": "Immutable delta explaining why a new learning path version was created.",
      "properties": {
        "schema_version": {
          "const": "topic2.path-change.v1",
          "default": "topic2.path-change.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "change_id": {
          "format": "uuid",
          "title": "Change Id",
          "type": "string"
        },
        "learner_ref": {
          "maxLength": 256,
          "minLength": 3,
          "title": "Learner Ref",
          "type": "string"
        },
        "course_id": {
          "maxLength": 64,
          "minLength": 3,
          "title": "Course Id",
          "type": "string"
        },
        "from_path_snapshot_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "From Path Snapshot Id"
        },
        "to_path_snapshot_id": {
          "format": "uuid",
          "title": "To Path Snapshot Id",
          "type": "string"
        },
        "change_type": {
          "$ref": "#/$defs/Topic2PathChangeType"
        },
        "reason": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "policy_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Policy Version",
          "type": "string"
        },
        "change_document": {
          "additionalProperties": true,
          "title": "Change Document",
          "type": "object"
        },
        "occurred_at": {
          "format": "date-time",
          "title": "Occurred At",
          "type": "string"
        }
      },
      "required": [
        "change_id",
        "learner_ref",
        "course_id",
        "to_path_snapshot_id",
        "change_type",
        "reason",
        "policy_version",
        "change_document",
        "occurred_at"
      ],
      "title": "Topic2PathChangeV1",
      "type": "object"
    },
    "Topic2PathPlanType": {
      "enum": [
        "INITIAL",
        "REPLANNED",
        "MANUAL_OVERRIDE",
        "RESTORED"
      ],
      "title": "Topic2PathPlanType",
      "type": "string"
    },
    "Topic2ProfileDimension": {
      "enum": [
        "KNOWLEDGE_MASTERY",
        "PROBLEM_SOLVING_PROFICIENCY",
        "MISCONCEPTION_PREFERENCE",
        "LEARNING_PACE",
        "FORGETTING_RATE",
        "LEARNING_GOAL_TENDENCY"
      ],
      "title": "Topic2ProfileDimension",
      "type": "string"
    },
    "Topic2ProfileFeatureV1": {
      "additionalProperties": false,
      "description": "Evidence-backed feature supporting one six-dimensional profile snapshot.",
      "properties": {
        "schema_version": {
          "const": "topic2.profile-feature.v1",
          "default": "topic2.profile-feature.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "feature_id": {
          "format": "uuid",
          "title": "Feature Id",
          "type": "string"
        },
        "dimension": {
          "$ref": "#/$defs/Topic2ProfileDimension"
        },
        "feature_key": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Feature Key",
          "type": "string"
        },
        "value_document": {
          "additionalProperties": true,
          "title": "Value Document",
          "type": "object"
        },
        "normalized_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Normalized Score",
          "type": "number"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence_count": {
          "minimum": 0,
          "title": "Evidence Count",
          "type": "integer"
        },
        "source_event_ids": {
          "items": {
            "type": "string"
          },
          "maxItems": 5000,
          "title": "Source Event Ids",
          "type": "array"
        },
        "computed_at": {
          "format": "date-time",
          "title": "Computed At",
          "type": "string"
        }
      },
      "required": [
        "feature_id",
        "dimension",
        "feature_key",
        "value_document",
        "normalized_score",
        "confidence",
        "evidence_count",
        "computed_at"
      ],
      "title": "Topic2ProfileFeatureV1",
      "type": "object"
    },
    "Topic2StudentProfileV1": {
      "additionalProperties": false,
      "description": "Immutable profile aggregate, full evidence features, and audit binding.",
      "properties": {
        "schema_version": {
          "const": "topic2.student-profile.v1",
          "default": "topic2.student-profile.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "profile_id": {
          "format": "uuid",
          "title": "Profile Id",
          "type": "string"
        },
        "learner_ref": {
          "maxLength": 256,
          "minLength": 3,
          "title": "Learner Ref",
          "type": "string"
        },
        "course_id": {
          "maxLength": 64,
          "minLength": 3,
          "title": "Course Id",
          "type": "string"
        },
        "profile_version": {
          "minimum": 1,
          "title": "Profile Version",
          "type": "integer"
        },
        "parent_profile_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Profile Id"
        },
        "policy_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Policy Version",
          "type": "string"
        },
        "knowledge_mastery": {
          "maximum": 1,
          "minimum": 0,
          "title": "Knowledge Mastery",
          "type": "number"
        },
        "problem_solving_proficiency": {
          "maximum": 1,
          "minimum": 0,
          "title": "Problem Solving Proficiency",
          "type": "number"
        },
        "misconception_preference": {
          "maximum": 1,
          "minimum": 0,
          "title": "Misconception Preference",
          "type": "number"
        },
        "learning_pace": {
          "maximum": 1,
          "minimum": 0,
          "title": "Learning Pace",
          "type": "number"
        },
        "forgetting_rate": {
          "maximum": 1,
          "minimum": 0,
          "title": "Forgetting Rate",
          "type": "number"
        },
        "learning_goal_tendency": {
          "maximum": 1,
          "minimum": 0,
          "title": "Learning Goal Tendency",
          "type": "number"
        },
        "confidence_score": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence Score",
          "type": "number"
        },
        "activity_count": {
          "minimum": 0,
          "title": "Activity Count",
          "type": "integer"
        },
        "last_event_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Event At"
        },
        "source_window_start": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Window Start"
        },
        "source_window_end": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Window End"
        },
        "profile_document": {
          "additionalProperties": true,
          "title": "Profile Document",
          "type": "object"
        },
        "content_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Sha256",
          "type": "string"
        },
        "frozen_at": {
          "format": "date-time",
          "title": "Frozen At",
          "type": "string"
        },
        "features": {
          "items": {
            "$ref": "#/$defs/Topic2ProfileFeatureV1"
          },
          "maxItems": 10000,
          "minItems": 6,
          "title": "Features",
          "type": "array"
        },
        "audit_event_id": {
          "format": "uuid",
          "title": "Audit Event Id",
          "type": "string"
        },
        "created_by_subject": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Created By Subject",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "profile_id",
        "learner_ref",
        "course_id",
        "profile_version",
        "policy_version",
        "knowledge_mastery",
        "problem_solving_proficiency",
        "misconception_preference",
        "learning_pace",
        "forgetting_rate",
        "learning_goal_tendency",
        "confidence_score",
        "activity_count",
        "profile_document",
        "content_sha256",
        "frozen_at",
        "features",
        "audit_event_id",
        "created_by_subject",
        "created_at"
      ],
      "title": "Topic2StudentProfileV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Single personalization input consumed by Lecturer and Tester agents.",
  "properties": {
    "schema_version": {
      "const": "topic2.agent-context.v1",
      "default": "topic2.agent-context.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "learner_ref": {
      "maxLength": 256,
      "minLength": 3,
      "title": "Learner Ref",
      "type": "string"
    },
    "course_id": {
      "maxLength": 64,
      "minLength": 3,
      "title": "Course Id",
      "type": "string"
    },
    "profile": {
      "$ref": "#/$defs/Topic2StudentProfileV1"
    },
    "memory_states": {
      "items": {
        "$ref": "#/$defs/Topic2MemoryStateV1"
      },
      "maxItems": 500,
      "title": "Memory States",
      "type": "array"
    },
    "learning_path": {
      "$ref": "#/$defs/Topic2LearningPathRecordV1"
    },
    "personalization_policy_digest": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Personalization Policy Digest",
      "type": "string"
    }
  },
  "required": [
    "learner_ref",
    "course_id",
    "profile",
    "memory_states",
    "learning_path",
    "personalization_policy_digest"
  ],
  "title": "Topic2AgentContextV1",
  "type": "object"
}
