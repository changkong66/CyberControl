{
  "$defs": {
    "ModuleDispatchItemV1": {
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "description": "Root trace propagated from Topic 3 ingestion.",
          "maxLength": 64,
          "minLength": 16,
          "pattern": "^[a-fA-F0-9]{16,64}$",
          "title": "Trace Id",
          "type": "string"
        },
        "tenant_id": {
          "description": "Trusted server-side tenant boundary.",
          "maxLength": 128,
          "minLength": 1,
          "title": "Tenant Id",
          "type": "string"
        },
        "version_cas": {
          "description": "Optimistic concurrency version.",
          "minimum": 1,
          "title": "Version Cas",
          "type": "integer"
        },
        "record_sha256": {
          "description": "Canonical immutable record digest.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Record Sha256",
          "type": "string"
        },
        "created_at": {
          "description": "UTC record creation time.",
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "immutable": {
          "const": true,
          "description": "Records are append-only once emitted.",
          "title": "Immutable",
          "type": "boolean"
        },
        "schema_version": {
          "const": "module-dispatch-item.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "dispatch_item_id": {
          "format": "uuid",
          "title": "Dispatch Item Id",
          "type": "string"
        },
        "claim_id": {
          "format": "uuid",
          "title": "Claim Id",
          "type": "string"
        },
        "module": {
          "$ref": "#/$defs/VerificationModule"
        },
        "required": {
          "title": "Required",
          "type": "boolean"
        },
        "priority": {
          "maximum": 1000,
          "minimum": 0,
          "title": "Priority",
          "type": "integer"
        },
        "dependency_item_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 16,
          "title": "Dependency Item Ids",
          "type": "array"
        },
        "timeout_ms": {
          "maximum": 120000,
          "minimum": 100,
          "title": "Timeout Ms",
          "type": "integer"
        },
        "max_attempts": {
          "maximum": 5,
          "minimum": 1,
          "title": "Max Attempts",
          "type": "integer"
        }
      },
      "required": [
        "trace_id",
        "tenant_id",
        "version_cas",
        "record_sha256",
        "created_at",
        "immutable",
        "schema_version",
        "dispatch_item_id",
        "claim_id",
        "module",
        "required",
        "priority",
        "timeout_ms",
        "max_attempts"
      ],
      "title": "ModuleDispatchItemV1",
      "type": "object"
    },
    "VerificationModule": {
      "enum": [
        "C2_RAG",
        "C3_ACADEMIC",
        "C4_GRAPH",
        "C5_QUIZ",
        "C6_CODE",
        "C7_EXTENSION",
        "C9_SECURITY",
        "C10_PRIVACY",
        "C11_COMPLIANCE"
      ],
      "title": "VerificationModule",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "module-dispatch-plan.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "dispatch_plan_id": {
      "format": "uuid",
      "title": "Dispatch Plan Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 4096,
      "minItems": 1,
      "title": "Claim Ids",
      "type": "array"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/ModuleDispatchItemV1"
      },
      "maxItems": 36864,
      "minItems": 1,
      "title": "Items",
      "type": "array"
    },
    "max_parallelism": {
      "maximum": 32,
      "minimum": 1,
      "title": "Max Parallelism",
      "type": "integer"
    },
    "policy_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Policy Version",
      "type": "string"
    },
    "plan_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Plan Sha256",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "dispatch_plan_id",
    "verification_id",
    "claim_ids",
    "items",
    "max_parallelism",
    "policy_version",
    "plan_sha256"
  ],
  "title": "ModuleDispatchPlanV1",
  "type": "object"
}
