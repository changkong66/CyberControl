    "AuthoritySourceRefV1": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Source Id",
          "type": "string"
        },
        "source_version": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Source Version",
          "type": "string"
        },
        "locator": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "content_sha256": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 64,
              "pattern": "^[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        }
      },
      "required": [
        "source_id",
        "source_version",
        "locator"
      ],
      "title": "AuthoritySourceRefV1",
      "type": "object"
    },
    "CourseStatus": {
      "enum": [
        "DRAFT",
        "ACTIVE",
        "ARCHIVED"
      ],
      "title": "CourseStatus",
      "type": "string"
    },
    "GoldenQuestionType": {
      "enum": [
        "SINGLE_CHOICE",
