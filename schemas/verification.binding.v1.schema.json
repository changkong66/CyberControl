{
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "verification.binding.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "state_machine_version": {
      "title": "State Machine Version",
      "type": "string"
    },
    "verifier_build_version": {
      "title": "Verifier Build Version",
      "type": "string"
    },
    "policy_version": {
      "title": "Policy Version",
      "type": "string"
    },
    "prompt_bundle_version": {
      "title": "Prompt Bundle Version",
      "type": "string"
    },
    "claim_schema_version": {
      "const": "claim.v1",
      "title": "Claim Schema Version",
      "type": "string"
    },
    "retrieval_pipeline_version": {
      "title": "Retrieval Pipeline Version",
      "type": "string"
    },
    "knowledge_base_version": {
      "title": "Knowledge Base Version",
      "type": "string"
    },
    "toolchain_manifest_version": {
      "title": "Toolchain Manifest Version",
      "type": "string"
    },
    "content_security_policy_version": {
      "title": "Content Security Policy Version",
      "type": "string"
    },
    "license_policy_version": {
      "title": "License Policy Version",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "state_machine_version",
    "verifier_build_version",
    "policy_version",
    "prompt_bundle_version",
    "claim_schema_version",
    "retrieval_pipeline_version",
    "knowledge_base_version",
    "toolchain_manifest_version",
    "content_security_policy_version",
    "license_policy_version"
  ],
  "title": "VerificationBindingV1",
  "type": "object"
}
