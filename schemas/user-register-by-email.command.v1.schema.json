{
  "$defs": {
    "RegistrationConsentV1": {
      "additionalProperties": false,
      "properties": {
        "privacy_policy_version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Privacy Policy Version",
          "type": "string"
        },
        "terms_of_service_version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Terms Of Service Version",
          "type": "string"
        },
        "privacy_policy_accepted": {
          "const": true,
          "title": "Privacy Policy Accepted",
          "type": "boolean"
        },
        "terms_of_service_accepted": {
          "const": true,
          "title": "Terms Of Service Accepted",
          "type": "boolean"
        }
      },
      "required": [
        "privacy_policy_version",
        "terms_of_service_version",
        "privacy_policy_accepted",
        "terms_of_service_accepted"
      ],
      "title": "RegistrationConsentV1",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "user-register-by-email.command.v1",
      "default": "user-register-by-email.command.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "challenge_id": {
      "format": "uuid",
      "title": "Challenge Id",
      "type": "string"
    },
    "email": {
      "maxLength": 320,
      "minLength": 3,
      "title": "Email",
      "type": "string"
    },
    "password": {
      "format": "password",
      "title": "Password",
      "type": "string",
      "writeOnly": true
    },
    "display_name": {
      "maxLength": 255,
      "minLength": 1,
      "title": "Display Name",
      "type": "string"
    },
    "preferred_locale": {
      "default": "zh-CN",
      "pattern": "^(zh-CN|zh-TW|en-US)$",
      "title": "Preferred Locale",
      "type": "string"
    },
    "consent": {
      "$ref": "#/$defs/RegistrationConsentV1"
    },
    "invitation_token": {
      "anyOf": [
        {
          "maxLength": 4096,
          "minLength": 32,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Invitation Token"
    }
  },
  "required": [
    "challenge_id",
    "email",
    "password",
    "display_name",
    "consent"
  ],
  "title": "UserRegisterByEmailCommandV1",
  "type": "object"
}
