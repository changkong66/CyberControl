{
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "fact-synthesis.request.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "fact_synthesis_request_id": {
      "format": "uuid",
      "title": "Fact Synthesis Request Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "evidence_bundle_id": {
      "format": "uuid",
      "title": "Evidence Bundle Id",
      "type": "string"
    },
    "deterministic_result_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 128,
      "title": "Deterministic Result Ids",
      "type": "array"
    },
    "provider_alias": {
      "const": "spark_text",
      "title": "Provider Alias",
      "type": "string"
    },
    "prompt_bundle_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Prompt Bundle Version",
      "type": "string"
    },
    "response_schema_version": {
      "const": "fact-synthesis.result.v1",
      "title": "Response Schema Version",
      "type": "string"
    },
    "deadline_at": {
      "format": "date-time",
      "title": "Deadline At",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "fact_synthesis_request_id",
    "verification_id",
    "claim_id",
    "evidence_bundle_id",
    "provider_alias",
    "prompt_bundle_version",
    "response_schema_version",
    "deadline_at"
  ],
  "title": "FactSynthesisRequestV1",
  "type": "object"
}
