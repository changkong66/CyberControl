{
  "$defs": {
    "EquivalenceMethod": {
      "enum": [
        "SYMBOLIC",
        "NUMERIC",
        "HYBRID"
      ],
      "title": "EquivalenceMethod",
      "type": "string"
    },
    "NumericCounterexampleV1": {
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "description": "Root trace propagated from Topic 3 ingestion.",
          "maxLength": 64,
          "minLength": 16,
          "pattern": "^[a-fA-F0-9]{16,64}$",
          "title": "Trace Id",
          "type": "string"
        },
        "tenant_id": {
          "description": "Trusted server-side tenant boundary.",
          "maxLength": 128,
          "minLength": 1,
          "title": "Tenant Id",
          "type": "string"
        },
        "version_cas": {
          "description": "Optimistic concurrency version.",
          "minimum": 1,
          "title": "Version Cas",
          "type": "integer"
        },
        "record_sha256": {
          "description": "Canonical immutable record digest.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Record Sha256",
          "type": "string"
        },
        "created_at": {
          "description": "UTC record creation time.",
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "immutable": {
          "const": true,
          "description": "Records are append-only once emitted.",
          "title": "Immutable",
          "type": "boolean"
        },
        "schema_version": {
          "const": "numeric-counterexample.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "assignments": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Assignments",
          "type": "object"
        },
        "left_value": {
          "title": "Left Value",
          "type": "number"
        },
        "right_value": {
          "title": "Right Value",
          "type": "number"
        },
        "absolute_error": {
          "minimum": 0.0,
          "title": "Absolute Error",
          "type": "number"
        },
        "relative_error": {
          "minimum": 0.0,
          "title": "Relative Error",
          "type": "number"
        }
      },
      "required": [
        "trace_id",
        "tenant_id",
        "version_cas",
        "record_sha256",
        "created_at",
        "immutable",
        "schema_version",
        "assignments",
        "left_value",
        "right_value",
        "absolute_error",
        "relative_error"
      ],
      "title": "NumericCounterexampleV1",
      "type": "object"
    },
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "formula-equivalence.result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "formula_equivalence_result_id": {
      "format": "uuid",
      "title": "Formula Equivalence Result Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "left_formula_ir_id": {
      "format": "uuid",
      "title": "Left Formula Ir Id",
      "type": "string"
    },
    "right_formula_ir_id": {
      "format": "uuid",
      "title": "Right Formula Ir Id",
      "type": "string"
    },
    "equivalent": {
      "title": "Equivalent",
      "type": "boolean"
    },
    "method": {
      "$ref": "#/$defs/EquivalenceMethod"
    },
    "tolerance": {
      "exclusiveMinimum": 0.0,
      "maximum": 0.01,
      "title": "Tolerance",
      "type": "number"
    },
    "sampled_points": {
      "maximum": 100000,
      "minimum": 0,
      "title": "Sampled Points",
      "type": "integer"
    },
    "counterexamples": {
      "items": {
        "$ref": "#/$defs/NumericCounterexampleV1"
      },
      "maxItems": 128,
      "title": "Counterexamples",
      "type": "array"
    },
    "verdict": {
      "$ref": "#/$defs/VerificationVerdict"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "toolchain_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Toolchain Version",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "formula_equivalence_result_id",
    "verification_id",
    "claim_id",
    "left_formula_ir_id",
    "right_formula_ir_id",
    "equivalent",
    "method",
    "tolerance",
    "sampled_points",
    "verdict",
    "confidence",
    "toolchain_version"
  ],
  "title": "FormulaEquivalenceResultV1",
  "type": "object"
}
