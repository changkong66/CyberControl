      "title": "Direction",
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/VerifierGraphNodeV1"
      },
      "maxItems": 4096,
      "minItems": 1,
      "title": "Nodes",
      "type": "array"
    },
    "edges": {
      "items": {
