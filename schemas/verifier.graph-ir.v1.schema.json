  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "verifier_graph_ir_id",
    "verification_id",
    "claim_id",
    "candidate_id",
    "candidate_version",
    "block_id",
    "mermaid_version",
    "direction",
    "nodes"
  ],
  "title": "VerifierGraphIRV1",
  "type": "object"
