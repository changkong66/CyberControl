{
  "$defs": {
    "TheoremConditionResultV1": {
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "description": "Root trace propagated from Topic 3 ingestion.",
          "maxLength": 64,
          "minLength": 16,
          "pattern": "^[a-fA-F0-9]{16,64}$",
          "title": "Trace Id",
          "type": "string"
        },
        "tenant_id": {
          "description": "Trusted server-side tenant boundary.",
          "maxLength": 128,
          "minLength": 1,
          "title": "Tenant Id",
          "type": "string"
        },
        "version_cas": {
          "description": "Optimistic concurrency version.",
          "minimum": 1,
          "title": "Version Cas",
          "type": "integer"
        },
        "record_sha256": {
          "description": "Canonical immutable record digest.",
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Record Sha256",
          "type": "string"
        },
        "created_at": {
          "description": "UTC record creation time.",
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "immutable": {
          "const": true,
          "description": "Records are append-only once emitted.",
          "title": "Immutable",
          "type": "boolean"
        },
        "schema_version": {
          "const": "theorem-condition-result.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "condition_id": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Condition Id",
          "type": "string"
        },
        "satisfied": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Satisfied"
        },
        "evidence_ref_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 128,
          "title": "Evidence Ref Ids",
          "type": "array"
        },
        "reason": {
          "maxLength": 4096,
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "trace_id",
        "tenant_id",
        "version_cas",
        "record_sha256",
        "created_at",
        "immutable",
        "schema_version",
        "condition_id",
        "satisfied",
        "reason"
      ],
      "title": "TheoremConditionResultV1",
      "type": "object"
    },
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
