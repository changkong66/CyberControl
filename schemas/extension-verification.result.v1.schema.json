{
  "$defs": {
    "VerificationVerdict": {
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "CONTRADICTED",
        "INSUFFICIENT_EVIDENCE",
        "UNSAFE",
        "NOT_APPLICABLE",
        "ERROR"
      ],
      "title": "VerificationVerdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "extension-verification.result.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "extension_verification_result_id": {
      "format": "uuid",
      "title": "Extension Verification Result Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "extension_resource_id": {
      "format": "uuid",
      "title": "Extension Resource Id",
      "type": "string"
    },
    "source_present_in_approved_corpus": {
      "title": "Source Present In Approved Corpus",
      "type": "boolean"
    },
    "citation_valid": {
      "title": "Citation Valid",
      "type": "boolean"
    },
    "license_compatible": {
      "title": "License Compatible",
      "type": "boolean"
    },
    "knowledge_relevance": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Knowledge Relevance",
      "type": "number"
    },
    "temporal_validity": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "title": "Temporal Validity"
    },
    "finding_codes": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "title": "Finding Codes",
      "type": "array"
    },
    "evidence_ref_ids": {
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "maxItems": 512,
      "title": "Evidence Ref Ids",
      "type": "array"
    },
    "verdict": {
      "$ref": "#/$defs/VerificationVerdict"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "extension_verification_result_id",
    "verification_id",
    "claim_id",
    "extension_resource_id",
    "source_present_in_approved_corpus",
    "citation_valid",
    "license_compatible",
    "knowledge_relevance",
    "temporal_validity",
    "verdict",
    "confidence"
  ],
  "title": "ExtensionVerificationResultV1",
  "type": "object"
}
