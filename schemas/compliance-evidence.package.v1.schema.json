        "immutable": {
          "const": true,
          "description": "Records are append-only once emitted.",
          "title": "Immutable",
          "type": "boolean"
        },
        "schema_version": {
          "const": "build-provenance.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "build_provenance_id": {
          "format": "uuid",
          "title": "Build Provenance Id",
          "type": "string"
        },
        "code_artifact_id": {
          "format": "uuid",
          "title": "Code Artifact Id",
          "type": "string"
        },
        "builder_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Builder Id",
          "type": "string"
        },
        "builder_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Builder Version",
          "type": "string"
        },
        "toolchain_manifest_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
          "title": "Toolchain Manifest Version",
          "type": "string"
        },
        "source_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Source Sha256",
          "type": "string"
        },
        "build_output_artifact": {
          "$ref": "#/$defs/ArtifactObjectRefV1"
        },
        "build_output_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Build Output Sha256",
          "type": "string"
        },
        "sbom_manifest_id": {
          "format": "uuid",
          "title": "Sbom Manifest Id",
          "type": "string"
        },
        "sandbox_policy_id": {
          "format": "uuid",
          "title": "Sandbox Policy Id",
          "type": "string"
        },
        "reproducible": {
          "title": "Reproducible",
          "type": "boolean"
        },
        "build_command_sha256": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Build Command Sha256",
          "type": "string"
        }
      },
      "required": [
        "trace_id",
        "tenant_id",
        "version_cas",
        "record_sha256",
        "created_at",
        "immutable",
        "schema_version",
        "build_provenance_id",
        "code_artifact_id",
        "builder_id",
        "builder_version",
        "toolchain_manifest_version",
        "source_sha256",
        "build_output_artifact",
        "build_output_sha256",
        "sbom_manifest_id",
        "sandbox_policy_id",
        "reproducible",
        "build_command_sha256"
