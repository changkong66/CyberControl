{
  "$defs": {
    "RevisionCycleState": {
      "enum": [
        "PLANNED",
        "LOCKED",
        "GENERATING",
        "COMPLETED",
        "FAILED",
        "CANCELLED"
      ],
      "title": "RevisionCycleState",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "revision-cycle.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "revision_cycle_id": {
      "format": "uuid",
      "title": "Revision Cycle Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "parent_verification_id": {
      "format": "uuid",
      "title": "Parent Verification Id",
      "type": "string"
    },
    "candidate_id": {
      "format": "uuid",
      "title": "Candidate Id",
      "type": "string"
    },
    "base_candidate_version": {
      "minimum": 1,
      "title": "Base Candidate Version",
      "type": "integer"
    },
    "base_candidate_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Base Candidate Sha256",
      "type": "string"
    },
    "revision_round": {
      "maximum": 2,
      "minimum": 1,
      "title": "Revision Round",
      "type": "integer"
    },
    "state": {
      "$ref": "#/$defs/RevisionCycleState"
    },
    "lock_token": {
      "format": "uuid",
      "title": "Lock Token",
      "type": "string"
    },
    "lock_owner": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Lock Owner",
      "type": "string"
    },
    "lock_expires_at": {
      "format": "date-time",
      "title": "Lock Expires At",
      "type": "string"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "revision_cycle_id",
    "verification_id",
    "parent_verification_id",
    "candidate_id",
    "base_candidate_version",
    "base_candidate_sha256",
    "revision_round",
    "state",
    "lock_token",
    "lock_owner",
    "lock_expires_at"
  ],
  "title": "RevisionCycleV1",
  "type": "object"
}
