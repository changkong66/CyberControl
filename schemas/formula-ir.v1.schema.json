{
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "description": "Root trace propagated from Topic 3 ingestion.",
      "maxLength": 64,
      "minLength": 16,
      "pattern": "^[a-fA-F0-9]{16,64}$",
      "title": "Trace Id",
      "type": "string"
    },
    "tenant_id": {
      "description": "Trusted server-side tenant boundary.",
      "maxLength": 128,
      "minLength": 1,
      "title": "Tenant Id",
      "type": "string"
    },
    "version_cas": {
      "description": "Optimistic concurrency version.",
      "minimum": 1,
      "title": "Version Cas",
      "type": "integer"
    },
    "record_sha256": {
      "description": "Canonical immutable record digest.",
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Record Sha256",
      "type": "string"
    },
    "created_at": {
      "description": "UTC record creation time.",
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "immutable": {
      "const": true,
      "description": "Records are append-only once emitted.",
      "title": "Immutable",
      "type": "boolean"
    },
    "schema_version": {
      "const": "formula-ir.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "formula_ir_id": {
      "format": "uuid",
      "title": "Formula Ir Id",
      "type": "string"
    },
    "verification_id": {
      "format": "uuid",
      "title": "Verification Id",
      "type": "string"
    },
    "claim_id": {
      "format": "uuid",
      "title": "Claim Id",
      "type": "string"
    },
    "original_expression": {
      "maxLength": 8192,
      "minLength": 1,
      "title": "Original Expression",
      "type": "string"
    },
    "canonical_expression": {
      "maxLength": 8192,
      "minLength": 1,
      "title": "Canonical Expression",
      "type": "string"
    },
    "lhs_expression": {
      "anyOf": [
        {
          "maxLength": 4096,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lhs Expression"
    },
    "rhs_expression": {
      "anyOf": [
        {
          "maxLength": 4096,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rhs Expression"
    },
    "symbols": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Symbols",
      "type": "object"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "maxItems": 256,
      "title": "Assumptions",
      "type": "array"
    },
    "units": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Units",
      "type": "object"
    },
    "parser_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._/+:-]{0,127}$",
      "title": "Parser Version",
      "type": "string"
    },
    "expression_sha256": {
      "maxLength": 64,
      "minLength": 64,
      "pattern": "^[a-f0-9]{64}$",
      "title": "Expression Sha256",
      "type": "string"
    }
  },
  "required": [
    "trace_id",
    "tenant_id",
    "version_cas",
    "record_sha256",
    "created_at",
    "immutable",
    "schema_version",
    "formula_ir_id",
    "verification_id",
    "claim_id",
    "original_expression",
    "canonical_expression",
    "parser_version",
    "expression_sha256"
  ],
  "title": "FormulaIRV1",
  "type": "object"
}
