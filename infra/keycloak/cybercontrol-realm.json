{
  "realm": "cybercontrol",
  "displayName": "CyberControl Local Identity",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "bruteForceProtected": true,
  "passwordPolicy": "length(8)",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 28800,
  "roles": {
    "realm": [
      {
        "name": "learner",
        "description": "CyberControl learner role"
      },
      {
        "name": "reviewer",
        "description": "CyberControl human reviewer role"
      },
      {
        "name": "tenant-admin",
        "description": "CyberControl tenant account administrator role"
      }
    ]
  },
  "groups": [
    {
      "name": "learners",
      "realmRoles": [
        "learner"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "basic",
      "description": "OIDC subject claim required by the API token verifier",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "profile",
      "description": "Minimal local OIDC profile claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "full-name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "Minimal local OIDC email claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "email-verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "description": "OIDC client and realm role claims for least-privilege service tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "introspection.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        },
        {
          "name": "audience-resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "introspection.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "name": "cybercontrol-claims",
      "description": "Trusted tenant, role, permission and audience claims for local development",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "user.attribute": "foo"
          }
        },
        {
          "name": "application-permissions",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "permissions",
            "claim.name": "permissions",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false"
          }
        },
        {
          "name": "api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "cybercontrol-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "basic",
    "profile",
    "email",
    "cybercontrol-claims"
  ],
  "defaultOptionalClientScopes": [],
  "clientScopeMappings": {
    "realm-management": [
      {
        "client": "cybercontrol-registration-admin",
        "roles": [
          "manage-users",
          "query-users",
          "view-users"
        ]
      }
    ]
  },
  "clients": [
    {
      "clientId": "cybercontrol-api",
      "name": "CyberControl API",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "cybercontrol-registration-admin",
      "name": "CyberControl Registration Service",
      "enabled": true,
      "secret": "local-registration-admin-only",
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "roles"
      ]
    },
    {
      "clientId": "cybercontrol-workbench",
      "name": "CyberControl Workbench",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "fullScopeAllowed": true,
      "rootUrl": "http://localhost:5173",
      "baseUrl": "http://localhost:5173/",
      "redirectUris": [
        "http://localhost:5173/auth/callback",
        "http://localhost:5174/auth/callback",
        "http://127.0.0.1:5174/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://127.0.0.1:5174"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*##http://localhost:5174/*##http://127.0.0.1:5174/*"
      },
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "cybercontrol-claims"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "cybercontrol-cli",
      "name": "CyberControl Local Verification Client",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "cybercontrol-claims"
      ]
    }
  ],
  "users": [
    {
      "username": "learner",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Learner",
      "email": "learner@example.invalid",
      "attributes": {
        "tenant_id": [
          "demo-academy"
        ],
        "permissions": [
          "topic1:read topic2:read topic2:profile:read topic2:profile:write topic2:memory:read topic2:memory:write topic2:path:read topic2:path:write topic2:context:read topic3:read topic3:write topic3:generation:read topic3:generation:write topic3:generation:retry topic3:sse:read topic4:read topic4:verification:read topic4:verification:execute topic4:claim:read topic4:report:read topic4:rag:read topic4:revision:read topic4:trace:read topic4:sse:read account:profile:read account:profile:write account:contact:write"
        ]
      },
      "realmRoles": [
        "learner"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "learner-local-only",
          "temporary": false
        }
      ]
    },
    {
      "username": "reviewer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Reviewer",
      "email": "reviewer@example.invalid",
      "attributes": {
        "tenant_id": [
          "demo-academy"
        ],
        "permissions": [
          "topic1:read topic1:import topic1:freeze topic2:read topic2:profile:read topic2:profile:write topic2:memory:read topic2:memory:write topic2:path:read topic2:path:write topic2:context:read topic3:read topic3:write topic3:generation:read topic3:generation:write topic3:generation:retry topic3:sse:read topic4:read topic4:verification:read topic4:verification:execute topic4:claim:read topic4:report:read topic4:rag:read topic4:revision:read topic4:trace:read topic4:sse:read topic4:review:read topic4:review:write topic4:release:read topic4:release:write account:profile:read account:profile:write account:contact:write"
        ]
      },
      "realmRoles": [
        "reviewer"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "reviewer-local-only",
          "temporary": false
        }
      ]
    },
    {
      "username": "tenant-admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Tenant Admin",
      "email": "tenant-admin@example.invalid",
      "attributes": {
        "tenant_id": [
          "demo-academy"
        ],
        "permissions": [
          "topic1:read topic2:read topic2:profile:read topic2:memory:read topic2:path:read topic2:context:read topic3:read topic3:generation:read topic3:sse:read topic4:read topic4:verification:read topic4:claim:read topic4:report:read topic4:rag:read topic4:revision:read topic4:trace:read topic4:sse:read account:profile:read account:profile:write account:contact:write account:admin:read account:admin:write"
        ]
      },
      "realmRoles": [
        "tenant-admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "tenant-admin-local-only1",
          "temporary": false
        }
      ]
    },
    {
      "username": "service-account-cybercontrol-registration-admin",
      "enabled": true,
      "serviceAccountClientId": "cybercontrol-registration-admin",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "query-users",
          "view-users"
        ]
      }
    }
  ]
}
